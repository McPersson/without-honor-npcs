# Disable autocrlf on generated files, they always generate with LF
# Add any extra files or paths here to make git stop saying they
# are changed when only line endings change.
src/generated/**/.cache/cache text eol=lf
src/generated/**/*.json text eol=lf

# Нормализуем переносы строк во всём репозитории: текст хранится как LF.
* text=auto eol=lf

# Явно — основные текстовые типы проекта
*.java       text eol=lf
*.gradle     text eol=lf
*.properties text eol=lf
*.json        text eol=lf
*.mcmeta     text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.cfg        text eol=lf

# Бинарники — не трогать никогда
*.jar   binary
*.png   binary
*.webp  binary
*.ogg   binary
*.wav   binary
*.zip   binary
